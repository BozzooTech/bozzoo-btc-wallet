{
  "manifest_version": 3,
  "name": "Bozzoo HD Bitcoin Wallet",
  "version": "1.0.0",
  "description": "Privacy-focused Bitcoin wallet with robust security. Private keys never leave your device. Supports Legacy, SegWit & Taproot. Uses public blockchain explorer APIs for balance and history lookups. Includes a small transparent platform fee on outgoing transactions.",
  "icons": {
    "16": "assets/icon-16.png",
    "32": "assets/icon-32.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "assets/icon-16.png",
      "32": "assets/icon-32.png",
      "48": "assets/icon-48.png",
      "128": "assets/icon-128.png"
    },
    "default_title": "Bozzoo BTC Wallet"
  },
  "background": {
    "service_worker": "background.js",
    "scripts": [
      "background.js"
    ],
    "type": "module"
  },
  "permissions": [
    "storage",
    "alarms",
    "notifications"
  ],
  "host_permissions": [
    "https://mempool.space/*",
    "https://blockchain.info/*",
    "https://api.binance.com/*",
    "https://mempool.ninja/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}