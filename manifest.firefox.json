{
  "manifest_version": 3,
  "name": "Bozzoo Bitcoin Wallet",
  "version": "1.0.0",
  "description": "Open-source, non-custodial Bitcoin wallet. Supports Legacy, SegWit & Taproot.",
  "icons": {
    "16": "assets/icon-16.png",
    "32": "assets/icon-32.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "assets/icon-16.png",
      "32": "assets/icon-32.png",
      "48": "assets/icon-48.png",
      "128": "assets/icon-128.png"
    },
    "default_title": "Bozzoo BTC Wallet"
  },
  "background": {
    "scripts": [
      "background.js"
    ]
  },
  "permissions": [
    "storage",
    "alarms",
    "notifications"
  ],
  "host_permissions": [
    "https://mempool.space/*",
    "https://blockchain.info/*",
    "https://api.binance.com/*",
    "https://mempool.ninja/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "{c8c42c5b-d513-4f85-84df-646cdae63517}",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  }
}