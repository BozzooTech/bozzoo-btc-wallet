{
  "name": "bozzoo-btc-wallet",
  "version": "1.0.0",
  "description": "Open-source, non-custodial Bitcoin wallet. Supports Legacy, SegWit & Taproot.",
  "scripts": {
    "start": "webpack serve --mode development",
    "build": "webpack --mode production",
    "build:watch": "webpack --mode development --watch",
    "build:firefox": "cross-env BROWSER=firefox webpack --mode production",
    "build:all": "npm run build && npm run build:firefox",
    "build:live": "cross-env TARGET=live webpack --mode production",
    "deploy": "npm run build:live && gh-pages -d live",
    "setup": "npm ci && npm run package:all",
    "type-check": "tsc --noEmit",
    "lint": "eslint src/**/*.{js,ts}",
    "test": "jest --forceExit --detectOpenHandles",
    "test:coverage": "jest --coverage --forceExit --detectOpenHandles"
  },
  "dependencies": {
    "@bitcoinerlab/secp256k1": "^1.2.0",
    "@noble/hashes": "^1.3.3",
    "bip32": "^4.0.0",
    "bip39": "^3.1.0",
    "bitcoinjs-lib": "^6.1.5",
    "buffer": "^6.0.3",
    "ecpair": "^2.1.0",
    "process": "^0.11.10",
    "qrcode": "^1.5.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@esbuild-plugins/node-globals-polyfill": "^0.2.3",
    "@types/chrome": "^0.0.258",
    "@types/jest": "^30.0.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "archiver": "^8.0.0",
    "copy-webpack-plugin": "^14.0.0",
    "cross-env": "^7.0.3",
    "crypto-browserify": "^3.12.1",
    "css-loader": "^6.10.0",
    "gh-pages": "^6.3.0",
    "jest": "^30.4.2",
    "jimp": "^1.6.1",
    "mini-css-extract-plugin": "^2.8.1",
    "sharp": "^0.34.5",
    "stream-browserify": "^3.0.0",
    "ts-jest": "^29.4.11",
    "ts-loader": "^9.5.1",
    "tslib": "^2.8.1",
    "typescript": "^5.3.3",
    "webpack": "^5.107.2",
    "webpack-cli": "^7.0.3",
    "webpack-dev-server": "^5.2.4"
  },
  "overrides": {
    "elliptic": "^6.6.1",
    "uuid": "^11.1.1"
  },
  "author": "bsr",
  "license": "GPL-3.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/bsr-oss/bozzoo-btc-wallet"
  }
}